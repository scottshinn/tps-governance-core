# Database connection — same Postgres where @tpsdev/governance-core is deployed
TPS_DB_HOST=localhost
TPS_DB_PORT=5432
TPS_DB_NAME=governance_dev
TPS_DB_USER=postgres
TPS_DB_PASSWORD=postgres

# Default operator context (Phase 1 — no auth; Phase 3 will pull from session)
TPS_DEFAULT_ACTOR=kya-operator
TPS_DEFAULT_ROLE=governance_admin
